<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/registration_form"
            android:textSize="24sp"/>

        <!-- First Name -->
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/firstName"
            android:hint="@string/first_name"
            android:layout_marginTop="16dp"
            android:background="@android:drawable/edit_text"
            android:padding="10dp"
            tools:ignore="TextFields" />

        <!-- Last Name -->
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/lastName"
            android:hint="@string/last_name"
            android:background="@android:drawable/edit_text"
            android:layout_marginTop="10dp"
            android:padding="10dp"/>

        <!-- Email -->
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/email"
            android:hint="@string/email"
            android:inputType="textEmailAddress"
            android:background="@android:drawable/edit_text"
            android:layout_marginTop="10dp"
            android:padding="10dp"/>

        <!-- Password -->
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/password"
            android:hint="@string/password"
            android:inputType="textPassword"
            android:background="@android:drawable/edit_text"
            android:layout_marginTop="10dp"
            android:padding="10dp"/>

        <!-- Gender -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/gender"
            android:textStyle="bold"
            android:layout_marginTop="15dp"/>

        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/genderGroup"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/male"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/male"/>

            <RadioButton
                android:id="@+id/female"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/female"/>

            <RadioButton
                android:id="@+id/other"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/other"/>

        </RadioGroup>

        <!-- Age -->
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:drawable/edit_text"
            android:padding="10dp"
            android:id="@+id/age"
            android:hint="@string/age"
            android:inputType="number"
            android:layout_marginTop="10dp"
            />

        <!-- Preferences -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/preferences"
            android:textStyle="bold"
            android:layout_marginTop="15dp"/>

        <CheckBox android:layout_width="match_parent"
            android:layout_height="wrap_content" android:id="@+id/acrylic" android:text="Acrylic Painting"/>
        <CheckBox  android:layout_width="match_parent"
            android:layout_height="wrap_content" android:id="@+id/oil" android:text="Oil Painting"/>
        <CheckBox android:layout_width="match_parent"
            android:layout_height="wrap_content" android:id="@+id/water" android:text="Water Color Painting"/>

        <!-- Spinner -->
        <Spinner
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/spinner"
            android:layout_marginTop="10dp"/>

        <!-- Bio -->
        <EditText
            android:layout_width="match_parent"
            android:id="@+id/bio"
            android:hint="@string/share_about_yourself"
            android:background="@android:drawable/edit_text"
            android:padding="10dp"
            android:layout_height="120dp"
            android:gravity="top"
            android:layout_marginTop="10dp"/>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center">

            <Button
                android:id="@+id/resetBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reset"/>

            <Button
                android:id="@+id/submitBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/submit"
                android:layout_marginStart="20dp"
                android:background="@drawable/button_bg"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>